rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: verifică dacă utilizatorul autentificat e membru al agenției
    function isAgencyMember(agencyId) {
      return request.auth != null &&
        get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.agency_id == agencyId;
    }

    // Helper: verifică dacă utilizatorul e admin al agenției
    function isAgencyAdmin(agencyId) {
      return isAgencyMember(agencyId) &&
        get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.role == 'admin';
    }

    // Agenții — membrii pot citi, adminii pot modifica
    match /agencies/{agencyId} {
      allow read: if isAgencyMember(agencyId);
      allow update: if isAgencyAdmin(agencyId);
      allow create: if request.auth != null;
    }

    // Profile — fiecare vede și modifică profilul propriu; admin vede toată agenția
    match /profiles/{userId} {
      allow read: if request.auth.uid == userId ||
        isAgencyAdmin(resource.data.agency_id);
      allow create: if request.auth.uid == userId;
      allow update: if request.auth.uid == userId ||
        isAgencyAdmin(resource.data.agency_id);
    }

    // Clienți — agentul vede/modifică doar dosarele lui; admin vede toată agenția
    match /clients/{clientId} {
      allow read: if request.auth != null && (
        resource.data.agent_id == request.auth.uid ||
        isAgencyAdmin(resource.data.agency_id)
      );
      allow create: if request.auth != null &&
        request.resource.data.agent_id == request.auth.uid;
      allow update: if request.auth != null &&
        resource.data.agent_id == request.auth.uid;
    }

    // Documente — aceleași reguli ca clienții
    match /documents/{documentId} {
      allow read: if request.auth != null && (
        resource.data.agent_id == request.auth.uid ||
        isAgencyAdmin(
          get(/databases/$(database)/documents/clients/$(resource.data.client_id)).data.agency_id
        )
      );
      allow create: if request.auth != null &&
        request.resource.data.agent_id == request.auth.uid;
    }

    // Audit logs — doar citire pentru admin, scriere pentru membrii
    match /audit_logs/{logId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null &&
        isAgencyAdmin(
          get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.agency_id
        );
    }
  }
}
